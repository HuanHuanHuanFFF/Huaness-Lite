{
  "name": "huaness-lite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "corepack pnpm -r --if-present build",
    "clean": "corepack pnpm -r --if-present run clean",
    "demo:mock-run": "corepack pnpm --silent --filter @huaness-lite/core demo:mock-run",
    "build:clean": "corepack pnpm run clean && corepack pnpm build",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "test": "corepack pnpm -r --if-present test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
